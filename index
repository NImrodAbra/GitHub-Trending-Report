    padding: 3rem 2rem 2.5rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(ellipse, rgba(249,115,22,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
  .hero h1 {
    font-size: 2.2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.3rem;
  }
  .hero .subtitle {
    color: var(--text-muted);
    font-size: 1rem;
    font-weight: 400;
  }
  .hero .meta-row {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.2rem;
    flex-wrap: wrap;
  }
  .meta-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 0.35rem 0.9rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .meta-pill .val { color: var(--text); font-weight: 600; }

  .container { max-width: 1200px; margin: 0 auto; padding: 2rem; }

  /* Score bars */
  .score-section { margin-bottom: 3rem; }
  .score-section h2 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .score-bar-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.6rem;
    cursor: pointer;
    transition: transform 0.15s;
  }
  .score-bar-row:hover { transform: translateX(4px); }
  .score-bar-row:hover .bar-fill { filter: brightness(1.2); }

  .rank-num {
    width: 28px;
    text-align: right;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-muted);
    flex-shrink: 0;
  }
  .rank-num.top1 { color: var(--gold); }
  .rank-num.top2 { color: #c0c0c0; }
  .rank-num.top3 { color: #cd7f32; }

  .bar-label {
    width: 280px;
    flex-shrink: 0;
    font-size: 0.82rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
