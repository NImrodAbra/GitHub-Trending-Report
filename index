  .bar-fill.tier1 { background: linear-gradient(90deg, #f97316, #fb923c); }
  .bar-fill.tier2 { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
  .bar-fill.tier3 { background: linear-gradient(90deg, #6366f1, #818cf8); }
  .bar-fill.tier4 { background: linear-gradient(90deg, #475569, #64748b); }

  .bar-score {
    width: 50px;
    text-align: right;
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }

